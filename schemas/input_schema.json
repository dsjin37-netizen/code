{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "input_schema.json",
  "title": "User Input Schema",
  "description": "사용자가 입력한 종목 분석 요청을 정규화한 구조",
  "type": "object",
  "properties": {
    "ticker": {
      "type": "string",
      "description": "종목 티커. 없으면 빈 문자열"
    },
    "company_name": {
      "type": "string",
      "description": "종목명"
    },
    "market": {
      "type": "string",
      "enum": ["KOSPI", "KOSDAQ", "NYSE", "NASDAQ", "OTHER"],
      "description": "상장 시장"
    },
    "investment_horizon": {
      "type": "string",
      "enum": ["단기", "스윙", "중기", "장기"],
      "description": "투자 기간"
    },
    "risk_profile": {
      "type": "string",
      "enum": ["보수적", "중립", "공격적"],
      "description": "투자 성향"
    },
    "holding_status": {
      "type": "string",
      "enum": ["미보유", "보유중", "손실중", "수익중"],
      "description": "보유 여부"
    },
    "reference_price": {
      "type": ["number", "null"],
      "description": "기준 가격"
    },
    "capital_size": {
      "type": ["number", "null"],
      "description": "투자 가능 자본"
    },
    "max_loss_tolerance": {
      "type": ["number", "null"],
      "description": "최대 감내 손실"
    },
    "request_datetime": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}$",
      "description": "요청 일시 YYYY-MM-DD HH:mm:ss"
    },
    "data_cutoff": {
      "type": "string",
      "description": "데이터 기준일 YYYY-MM-DD 또는 '확인 필요'"
    }
  },
  "required": ["company_name", "market", "investment_horizon", "holding_status"],
  "additionalProperties": false
}
